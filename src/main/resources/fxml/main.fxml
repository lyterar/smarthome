<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smarthome.controller.MainController"
            stylesheets="@../css/theme-dark.css"
            prefWidth="320" prefHeight="700">

    <!-- Главное окно = диспетчер. Каждая функция — в своём окне. -->

    <left>
        <VBox prefWidth="300" styleClass="side-panel" spacing="8">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

            <!-- Заголовок -->
            <Label text="УМНЫЙ ДОМ" styleClass="app-title"/>
            <Label text="Главное меню" style="-fx-text-fill:#64748b; -fx-font-size:12px;"/>

            <Separator/>

            <!-- ══ КОМНАТЫ ══ -->
            <Label text="Комнаты" styleClass="panel-title"/>
            <ListView fx:id="roomListView" prefHeight="220" styleClass="dark-list"/>

            <HBox spacing="6">
                <Button text="+ Комната" onAction="#onAddRoom" styleClass="btn-primary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="−" onAction="#onRemoveRoom" styleClass="btn-danger" prefWidth="36"/>
            </HBox>

            <Separator/>

            <!-- ══ ОКНА — кнопки открытия ══ -->
            <Label text="Окна" styleClass="panel-title"/>
            <Label text="Каждое окно — отдельная задача"
                   style="-fx-text-fill:#475569; -fx-font-size:11px;"/>

            <!-- Вид (2D/3D/FPS) -->
            <Button text="🖥  Открыть вид  (2D / 3D / FPS)"
                    onAction="#onOpenViewWindow"
                    styleClass="btn-secondary"
                    maxWidth="Infinity"/>

            <!-- Устройства -->
            <Button text="💡  Устройства"
                    onAction="#onOpenDeviceWindow"
                    styleClass="btn-secondary"
                    maxWidth="Infinity"/>

            <!-- Автоматизация -->
            <Button text="⚙️  Автоматизация"
                    onAction="#onOpenAutomationWindow"
                    styleClass="btn-secondary"
                    maxWidth="Infinity"/>

            <!-- Журнал событий -->
            <Button text="📋  Журнал событий"
                    onAction="#onOpenLogWindow"
                    styleClass="btn-secondary"
                    maxWidth="Infinity"/>

            <Separator/>

            <!-- ══ ИСТОРИЯ КОМАНД ══ -->
            <HBox spacing="6">
                <Button fx:id="undoButton" text="↩ Отмена" onAction="#onUndo"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="redoButton" text="↪ Повтор" onAction="#onRedo"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <!-- ══ СОХРАНЕНИЕ ══ -->
            <HBox spacing="6">
                <Button text="Сохранить" onAction="#onSaveHouse" styleClass="btn-secondary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Загрузить" onAction="#onLoadHouse" styleClass="btn-secondary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <Separator/>

            <!-- ══ ТЕМА ══ -->
            <Label text="Тема" styleClass="panel-title"/>
            <HBox spacing="4">
                <Button fx:id="btnThemeDark"  text="Тёмная"  onAction="#onThemeDark"
                        styleClass="btn-theme-active" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnThemeLight" text="Светлая" onAction="#onThemeLight"
                        styleClass="btn-theme"        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnThemeBlue"  text="Синяя"   onAction="#onThemeBlue"
                        styleClass="btn-theme"        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <!-- Растягивающийся пустой блок — прижимает инфо к низу -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- ══ ИНФОРМАЦИЯ ══ -->
            <Separator/>
            <Label fx:id="houseInfoLabel" text="0 комнат" styleClass="house-info" wrapText="true"/>
        </VBox>
    </left>

    <!-- Статусная строка -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding><Insets top="5" right="10" bottom="5" left="10"/></padding>
            <Label fx:id="statusLabel" text="Готово"/>
        </HBox>
    </bottom>

</BorderPane>
